# Python Model Service - Configuration

# Service Configuration
SERVICE_NAME=python-model
OUTPUT_DIR=outputs
BASE_URL=http://localhost:8001
LOG_LEVEL=INFO

# Model Configuration
# Hugging Face model IDs for generation
MODEL_ID=runwayml/stable-diffusion-v1-5
INPAINT_MODEL_ID=runwayml/stable-diffusion-v1-5-inpainting

# Cache Configuration
# Models will be cached in one of these directories (in order of precedence):
# 1. HF_HOME environment variable
# 2. TRANSFORMERS_CACHE environment variable
# 3. ~/.cache/huggingface (default)
# 
# Set this to a custom directory if you want to store models elsewhere
# (useful if C: drive is full - set to another disk)
# HF_HOME=/data/huggingface_cache

# Model Loading Configuration
# Load all models at startup (reduces first request latency)
PRELOAD_MODEL=false

# Memory Optimization Flags
# Enable attention slicing to reduce memory usage
ENABLE_ATTENTION_SLICING=true
# Enable VAE slicing to reduce memory usage during encoding/decoding
ENABLE_VAE_SLICING=true
# Use low CPU memory loading
LOW_CPU_MEM_USAGE=true

# Inference Configuration
# Number of inference steps (higher = better quality, slower)
NUM_INFERENCE_STEPS=50
# Guidance scale for classifier-free guidance (higher = more adherent to prompt, but less creative)
GUIDANCE_SCALE=7.5

# Example: Production settings with preloading
# PRELOAD_MODEL=true
# NUM_INFERENCE_STEPS=50
# GUIDANCE_SCALE=7.5
# LOG_LEVEL=INFO

# Example: Fast inference with lower quality
# NUM_INFERENCE_STEPS=30
# GUIDANCE_SCALE=6.0

# Example: Custom cache directory (for large storage disk)
# HF_HOME=/mnt/large_disk/huggingface_cache
# PRELOAD_MODEL=true
